# Finance Seer Environment Configuration

# OpenAI / LLM Configuration (Optional - app works without these)
# For AI analysis reports, set your API key and endpoint
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Alternative providers (OpenAI-compatible):
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions              # OpenAI
# OPENAI_API_URL=https://YOUR_RESOURCE.openai.azure.com/v1/chat/completions  # Azure
# OPENAI_API_URL=http://localhost:8000/v1/chat/completions              # Local (llama.cpp, LM Studio)
# OPENAI_API_URL=http://192.168.10.163:1234/v1                          # GX10 LM Studio

# Database
# SQLite file path (auto-created, relative to project root)
DATABASE_URL=sqlite:./data/finance.db

# Next.js
NODE_ENV=development
