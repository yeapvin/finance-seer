{
  "crons": [
    { "path": "/api/portfolio/morning", "schedule": "0 13 * * 1-5" },  // 21:30 SGT - NYSE open (13:30 UTC)
    { "path": "/api/portfolio/midday", "schedule": "30 17 * * 1-5" }, // 01:30 SGT - NYSE midday (17:30 UTC)
    { "path": "/api/portfolio/close", "schedule": "5 20 * * 1-5" }    // 04:05 SGT - NYSE close (20:05 UTC, data feed)
  ],
  "functions": {
    "app/api/portfolio/monitor/route.ts": { "maxDuration": 60 },
    "app/api/portfolio/midday/route.ts":  { "maxDuration": 60 },
    "app/api/portfolio/close/route.ts":   { "maxDuration": 60 },
    "app/api/watchlist/analyze/route.ts": { "maxDuration": 60 },
    "app/api/basket/route.ts":            { "maxDuration": 60 },
    "app/api/analyze/route.ts":            { "maxDuration": 60 }
  }
}
